+        $display("\n=== Phase 6 Test: RV32M Divide/Remainder Instructions ===");
+
+        // Load DIV/REM test program at 0x140 (word addr 80)
+        // Common register init
+        load_word(10'd80, 32'h00A00513); // addi x10, x0, 10
