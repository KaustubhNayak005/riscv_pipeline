+        check_reg(28, 32'hFFFFFFFF,     "REM  (-10)%3");
+        check_reg(29, 32'd1,            "REM  10%(-3)");
+        check_reg(30, 32'd5,            "REM  5%0");
+        check_reg(2,  32'd0,            "REM  0x80000000%(-1)");
+
+        // Check REMU results (tests 14-15)
