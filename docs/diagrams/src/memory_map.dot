    uart [
        label="{0x80000000 region|0x80000000 UART_STATUS: bit0 tx_busy, bit1 rx_valid|0x80000004 UART_TX_DATA: write byte[7:0]|0x80000008 UART_RX_DATA: read byte[7:0], clears valid}",
        fillcolor="#fff4e6"
    ];

    perf [
